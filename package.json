{
  "name": "puzz",
  "version": "1.0.0",
  "description": "Drupal theme - Modern SDC-based",
  "type": "module",
  "author": "Daniel de la Iglesia",
  "license": "ISC",
  "scripts": {
    "postinstall": "patch-package",
    "build": "npm run build:prod",
    "build:dev": "node scripts/build.js dev",
    "build:prod": "node scripts/build.js prod",
    "build:icons": "node scripts/build.js icons",
    "dev": "node scripts/dev-server.js",
    "clean": "rimraf build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "cross-env STORYBOOK_BASE_PATH=/@storybook/ storybook build -o build-storybook"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/html-vite": "^10.2.10",
    "@tabler/icons": "^3.41.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "browser-sync": "^3.0.4",
    "chokidar": "^3.6.0",
    "cross-env": "^7.0.3",
    "fast-glob": "^3.3.3",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "postcss-sorting": "^8.0.2",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "sass": "^1.77.8",
    "storybook": "^10.2.10",
    "svgo": "^4.0.1",
    "svgstore": "^3.0.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "glob": "^11.0.1"
  }
}
