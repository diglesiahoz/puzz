{#
/**
 * @file
 * Section en view mode "component": renderiza vía componente SDC (puzz:section).
 * Misma lógica que paragraph--background_image--component: solo se invoca el componente con props.
 * El label lo renderiza el propio componente (props label_display, label_text).
 *
 * @see includes/preprocess.paragraph.inc
 */
#}
{% if component is defined and props is defined %}
  {{ {
    '#type': 'component',
    '#component': component ?? 'puzz:section',
    '#props': props
  } }}
{% else %}
  {{ content }}
{% endif %}
