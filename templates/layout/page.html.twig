{#
/**
 * @file
 * Theme override to display a single Drupal page.
 * Uses SDC components for hero, breadcrumb, and banner.
 * Header, main, and footer are rendered directly without SDC components.
 */
#}

{{ page_top }}

{# Header (navbar, header and menu) - rendered directly without SDC component #}
<div id="navbar-wrapper">
  <div id="navbar" role="banner">
    {{ page.navbar }}
    <button class="icon-menu">
      <span class="icon-menu-1"></span>
      <span class="icon-menu-2"></span>
      <span class="icon-menu-3"></span>
    </button>
  </div>
</div>

<div id="navbar-collapse">
  <header id="header" role="banner">
    <div class="container">
      <div id="header-wrapper">
        {{ page.header }}
        {% if page.menu %}
        <div id="menu" class="main-navigation">
          {{ page.menu }}
        </div>
        {% endif %}
        {{ page.header_menu }}
        {{ page.header_search }}
      </div>
    </div>
  </header>
</div>

{# Hero component #}
{{ {
  '#type': 'component',
  '#component': 'puzz:hero',
  '#props': {
    'hero_region': page.hero|default(''),
  }
} }}

{# Breadcrumb component #}
{{ {
  '#type': 'component',
  '#component': 'puzz:breadcrumb',
  '#props': {
    'breadcrumb_region': page.breadcrumb|default(''),
    'show_breadcrumb': not is_canvas_page and not is_front,
  }
} }}

{# Main content (includes content, title and sidebars) - rendered directly without SDC component #}
{%
  set content_classes = [
    page.sidebar_first and page.sidebar_second ? 'two-sidebars',
    page.sidebar_first and not page.sidebar_second ? 'one-sidebar sidebar-first',
    page.sidebar_second and not page.sidebar_first ? 'one-sidebar sidebar-second',
    not page.sidebar_first and not page.sidebar_second ? 'no-sidebars'
  ]
%}

<div id="center" class="{{ content_classes|join(' ') }}">
  <div class="container">
    <div class="region region-center">
      {% if page.sidebar_first %}
        <aside id="sidebar-first" class="sidebar" role="complementary">
          {{ page.sidebar_first }}
        </aside>
      {% endif %}

      <main id="main" role="main">
        <a id="main-content" tabindex="-1"></a>
        {% if not is_canvas_page and not is_front and page.title %}
          {{ page.title }}
        {% endif %}
        {{ page.content }}

        
        {#

        <h3>Components Examples</h3>

        {{ {
          '#type': 'component',
          '#component': 'puzz:cta',
          '#props': {
            'text': 'Primary CTA',
            'url': '#',
            'variant': 'primary',
            'size': 'medium'
          }
        } }}

        {{ {
          '#type': 'component',
          '#component': 'puzz:input',
          '#props': {
            'name': 'email',
            'label': 'Email',
            'type': 'email',
            'placeholder': 'tu@ejemplo.com',
            'required': true,
          }
        } }}

        {{ {
          '#type': 'component',
          '#component': 'puzz:icon',
          '#props': {
            'name': 'icon-search',

            'size': 'md',
            'label': 'Search',
            'color': 'red'

          }
        } }}

        {{ {
          '#type': 'component',
          '#component': 'puzz:icon',
          '#props': {
            'name': 'icon-search',

            'size': 'md',
            'label': 'Search',
            'color': '#0ea5e9'

          }
        } }}

        #}


        {#
        <section>
          <h2>Formulario de referencia (inventario de componentes)</h2>
          <p>Ejemplo funcional para identificar todos los componentes de formulario necesarios.</p>

          <form action="#" method="post" enctype="multipart/form-data">
            <fieldset>
              <legend>Datos personales</legend>

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-text',
                  'name': 'demo_text',
                  'label': 'Texto',
                  'type': 'text',
                  'placeholder': 'Nombre y apellidos'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-email',
                  'name': 'demo_email',
                  'label': 'Email',
                  'type': 'email',
                  'placeholder': 'tu@email.com',
                  'required': true
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-password',
                  'name': 'demo_password',
                  'label': 'Password',
                  'type': 'password',
                  'required': true
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-tel',
                  'name': 'demo_tel',
                  'label': 'Teléfono',
                  'type': 'tel',
                  'placeholder': '+34 600 000 000'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-date',
                  'name': 'demo_date',
                  'label': 'Fecha',
                  'type': 'date'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-time',
                  'name': 'demo_time',
                  'label': 'Hora',
                  'type': 'time'
                }
              } }}
            </fieldset>

            <fieldset>
              <legend>Preferencias</legend>

              {{ {
                '#type': 'component',
                '#component': 'puzz:select',
                '#props': {
                  'id': 'demo-select',
                  'name': 'demo_select',
                  'label': 'Select simple',
                  'options': [
                    {'type': 'option', 'value': '', 'label': 'Selecciona una opción', 'selected': true},
                    {'type': 'option', 'value': 'option_1', 'label': 'Opción 1'},
                    {'type': 'option', 'value': 'option_2', 'label': 'Opción 2'},
                    {'type': 'option', 'value': 'option_3', 'label': 'Opción 3'}
                  ]
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:select',
                '#props': {
                  'id': 'demo-multiselect',
                  'name': 'demo_multiselect[]',
                  'label': 'Select múltiple',
                  'multiple': true,
                  'options': [
                    {'type': 'option', 'value': 'multi_1', 'label': 'Multi 1', 'selected': true},
                    {'type': 'option', 'value': 'multi_2', 'label': 'Multi 2'},
                    {'type': 'option', 'value': 'multi_3', 'label': 'Multi 3'},
                    {'type': 'option', 'value': 'multi_4', 'label': 'Multi 4', 'selected': true}
                  ]
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:radio-group',
                '#props': {
                  'legend': 'Radio group',
                  'name': 'demo_radio',
                  'options': [
                    {'value': 'a', 'label': 'Opción A', 'checked': true},
                    {'value': 'b', 'label': 'Opción B'},
                    {'value': 'c', 'label': 'Opción C'}
                  ]
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:checkbox-group',
                '#props': {
                  'legend': 'Checkbox group',
                  'name': 'demo_check',
                  'options': [
                    {'value': 'news', 'label': 'Newsletter', 'checked': true},
                    {'value': 'events', 'label': 'Eventos'},
                    {'value': 'offers', 'label': 'Ofertas'}
                  ]
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input-range',
                '#props': {
                  'id': 'demo-range',
                  'name': 'demo_range',
                  'label': 'Range',
                  'value': '30',
                  'min': '0',
                  'max': '100',
                  'step': '1'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input-color',
                '#props': {
                  'id': 'demo-color',
                  'name': 'demo_color',
                  'label': 'Color',
                  'value': '#0ea5e9'
                }
              } }}
            </fieldset>

            <fieldset>
              <legend>Contenido y adjuntos</legend>

              {{ {
                '#type': 'component',
                '#component': 'puzz:textarea',
                '#props': {
                  'id': 'demo-textarea',
                  'name': 'demo_textarea',
                  'label': 'Textarea',
                  'rows': 5,
                  'placeholder': 'Escribe tu mensaje...'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:file-input',
                '#props': {
                  'id': 'demo-file',
                  'name': 'demo_file',
                  'label': 'File upload'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:file-input',
                '#props': {
                  'id': 'demo-files',
                  'name': 'demo_files[]',
                  'label': 'Multiple files',
                  'multiple': true
                }
              } }}
            </fieldset>

            <fieldset>
              <legend>Campos avanzados</legend>

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-search',
                  'name': 'demo_search',
                  'label': 'Search',
                  'type': 'search',
                  'placeholder': 'Buscar...'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-url',
                  'name': 'demo_url',
                  'label': 'URL',
                  'type': 'url',
                  'placeholder': 'https://example.com'
                }
              } }}

              {{ {
                '#type': 'component',
                '#component': 'puzz:input',
                '#props': {
                  'id': 'demo-number',
                  'name': 'demo_number',
                  'label': 'Number',
                  'type': 'number',
                  'min': '0',
                  'max': '999',
                  'step': '1',
                  'value': '10'
                }
              } }}

              <div>
                <label for="demo-hidden-label">Hidden (no visible)</label>
                <input id="demo-hidden-label" name="demo_hidden_label" type="hidden" value="hidden-value">
                <small>Campo hidden enviado en el submit.</small>
              </div>
            </fieldset>

            <div>
              {{ {
                '#type': 'component',
                '#component': 'puzz:cta',
                '#props': {
                  'text': 'Submit',
                  'url': '',
                  'variant': 'primary',
                  'size': 'medium',
                  'button_type': 'submit'
                }
              } }}
              {{ {
                '#type': 'component',
                '#component': 'puzz:cta',
                '#props': {
                  'text': 'Reset',
                  'url': '',
                  'variant': 'outline',
                  'size': 'medium',
                  'button_type': 'reset'
                }
              } }}
              {{ {
                '#type': 'component',
                '#component': 'puzz:cta',
                '#props': {
                  'text': 'Secondary action',
                  'url': '',
                  'variant': 'secondary',
                  'size': 'medium',
                  'button_type': 'button'
                }
              } }}
            </div>
          </form>
        </section>
        #}

      </main>

      {% if page.sidebar_second %}
        <aside id="sidebar-second" class="sidebar" role="complementary">
          {{ page.sidebar_second }}
        </aside>
      {% endif %}
    </div>
  </div>
</div>

{# Banner component #}
{{ {
  '#type': 'component',
  '#component': 'puzz:banner',
  '#props': {
    'banner_region': page.banners|default(''),
  }
} }}

{# Footer - rendered directly without SDC component #}
<footer id="footer" role="contentinfo">
  <div class="container">
    {% if page.footer %}
      <div class="region-footer">{{ page.footer }}</div>
    {% endif %}
  </div>
</footer>

{% if page.copyright %}
<div id="copyright" role="contentinfo">
  <div class="container">
    <div class="region">{{ page.copyright }}</div>
  </div>
</div>
{% endif %}

{{ page_bottom }}
